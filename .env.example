# Cerebras API key — server-side only. NEVER commit a real value.
CEREBRAS_API_KEY=

# Gemma 4 model id on Cerebras. Hard-required for the hackathon.
# Per Cerebras hackathon Q&A: "Model ID: gemma-4-31b". Do not rely on auto-discovery.
GROVE_GEMMA_MODEL=gemma-4-31b

# Soak knobs (defaults shown)
GROVE_SOAK_SECONDS=60
GROVE_SOAK_CONCURRENCY=25

# How many decide-prompt trials for the JSON fallback gate
GROVE_FALLBACK_TRIALS=20
